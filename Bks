-- [[ 👻 GHOST BYPASS V5 — NO-GUI CHAT EDITION 👻 ]]
-- Працює повністю в тіні. Античит не бачить об'єктів у CoreGui.
-- Керування через звичайний чат гри!

if not game:IsLoaded() then game.Loaded:Wait() end

-- Глобальні змінні контролю
getgenv().Autograb = false
getgenv().Desync = false
getgenv().Invisible = false
getgenv().Semi = false

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer

-- Повідомлення клієнту (бачиш ЛИШЕ ТИ в консолі F9 або локальному чаті)
local function Log(text)
    game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
        Text = "[GHOST]: " .. text,
        Color = Color3.fromRGB(0, 255, 120),
        Font = Enum.Font.SourceSansBold,
        TextSize = 15
    })
end

-- Безпечний віддалений івент для доставки
local function GetRemote()
    local Net = ReplicatedStorage:WaitForChild("Packages", 2):FindFirstChild("Net")
    if Net then
        return Net:FindFirstChild("RE/StealService/DeliverySteal")
    end
    return nil
end

-- ========================================================================
-- ⚙️ ЛОГІКА ФУНКЦІЙ (АКТИВУЄТЬСЯ ТІЛЬКИ ПІСЛЯ КОМАНДИ)
-- ========================================================================

-- 1. БЕЗПЕЧНИЙ АВТОЗБІР (Легітимний радіус)
task.spawn(function()
    while true do
        task.wait(0.4)
        if getgenv().Autograb then
            pcall(function()
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, prompt in pairs(Workspace:GetDescendants()) do
                        if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                            if (hrp.Position - prompt.Parent:GetPivot().Position).Magnitude <= 12 then
                                fireproximityprompt(prompt, 0)
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- 2. ЛЕГІТИМНИЙ ДЕСИНХРОН (Кути нахилу)
RunService.Heartbeat:Connect(function()
    if getgenv().Desync then
        pcall(function()
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(math.random(-4, 4)), 0)
            end
        end)
    end
end)

-- 3. БЕЗПЕЧНА КРАДІЖКА ПІД КАРТОЮ (LinearVelocity без ТП-детекту)
local Attachment, LinearVelocity
local function ToggleInvisible(state)
    pcall(function()
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        
        if state and hrp and hum then
            hum.PlatformStand = true
            Attachment = Instance.new("Attachment", hrp)
            LinearVelocity = Instance.new("LinearVelocity", hrp)
            LinearVelocity.Attachment0 = Attachment
            LinearVelocity.RelativeTo = Enum.ActuatorRelativeTo.World
            LinearVelocity.MaxForce = math.huge
            
            LinearVelocity.VectorVelocity = Vector3.new(0, -11, 0)
            task.wait(0.2)
            LinearVelocity.VectorVelocity = Vector3.zero
            
            local remote = GetRemote()
            if remote then remote:FireServer() end
        else
            if LinearVelocity then LinearVelocity:Destroy() end
            if Attachment then Attachment:Destroy() end
            if hum then 
                hum.PlatformStand = false 
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
            if hrp then hrp.CFrame = hrp.CFrame * CFrame.new(0, 12, 0) end
        end
    end)
end

-- ========================================================================
-- 🗣️ КЕРУВАННЯ ЧЕРЕЗ ЧАТ
-- ========================================================================
LocalPlayer.Chatted:Connect(function(message)
    local msg = message:lower()
    
    if msg == ".grab" then
        getgenv().Autograb = not getgenv().Autograb
        Log("Autograb змінено на: " .. tostring(getgenv().Autograb))
        
    elseif msg == ".desync" then
        getgenv().Desync = not getgenv().Desync
        Log("Desync змінено на: " .. tostring(getgenv().Desync))
        
    elseif msg == ".steal" then
        getgenv().Invisible = not getgenv().Invisible
        ToggleInvisible(getgenv().Invisible)
        Log("Invisible Steal змінено на: " .. tostring(getgenv().Invisible))
        
    elseif msg == ".semi" then
        getgenv().Semi = not getgenv().Semi
        pcall(function()
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if (part:IsA("BasePart") or part:IsA("Decal")) and part.Name ~= "HumanoidRootPart" then
                    part.Transparency = getgenv().Semi and 0.7 or 0
                end
            end
        end)
        Log("Semi-Invisible змінено на: " .. tostring(getgenv().Semi))
    end
end)

Log("СКРИПТ ЗАВАНТАЖЕНО В ТІНЬОВОМУ РЕЖИМІ!")
Log("Команди для чату: .grab | .desync | .steal | .semi")



