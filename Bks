end)

-- 3. БЕЗПЕЧНА КРАДІЖКА ПІД КАРТОЮ (Телепорт без руйнування моделі персонажа)
CreateToggle("Semi-Invisible Steal", 3, function(state)
    getgenv().GhostInvisible = state
    pcall(function()
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if state and hrp then
            -- Безпечно опускаємо клієнта під підлогу на -12 блоків (гравці тебе не бачать)
            hrp.CFrame = hrp.CFrame * CFrame.new(0, -12, 0)
            
            -- Виклик зашифрованого пакету доставки
            local stealRemote = GetSafeRemote("RE/StealService/DeliverySteal")
            if stealRemote then
                stealRemote:FireServer()
            end
        elseif not state and hrp then
            -- Повертаємо на поверхню
            hrp.CFrame = hrp.CFrame * CFrame.new(0, 13, 0)
        end
    end)
end)

-- 4. НАПІВНЕВИДИМІСТЬ (Для FPS та маскування)
CreateToggle("Semi Transparent", 4, function(state)
    getgenv().GhostSemi = state
    pcall(function()
        local char = LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if (part:IsA("BasePart") or part:IsA("Decal")) and part.Name ~= "HumanoidRootPart" then
                    part.Transparency = state and 0.65 or 0
                end
            end
        end
    end)
end)

