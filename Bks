-- ========================================================================
-- ФУНКЦІЯ 1: DESYNC (ДЕСИНХРОНІЗАЦІЯ КЛІЄНТА)
-- ========================================================================
-- Логіка взята та оптимізована з файлів Tokino Desync та BKHUB
local function ToggleDesync(state)
    getgenv().DesyncEnabled = state
    if state then
        Connections["Desync"] = RunService.Heartbeat:Connect(function()
            if not getgenv().DesyncEnabled then return end
            pcall(function()
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    -- Швидка зміна CFrame або Velocity для збиття синхронізації з сервером
                    local oldCFrame = hrp.CFrame
                    hrp.CFrame = oldCFrame * CFrame.new(0, math.random(500, 1000), 0)
                    RunService.RenderStepped:Wait()
                    hrp.CFrame = oldCFrame
                end
            end)
        end)
        Rayfield:Notify({Title = "Desync", Content = "Десинхронізація активована!", Duration = 3})
    else
        if Connections["Desync"] then
            Connections["Desync"]:Disconnect()
            Connections["Desync"] = nil
        end
    end
end

-- ========================================================================
-- ФУНКЦІЯ 2: AUTOGRAB / AUTO-PICKUP (АВТОМАТИЧНИЙ ЗБІР)
-- ========================================================================
-- Адаптовано з урахуванням ProximityPromptService з файлу Xen_Hub
local function ToggleAutograb(state)
    getgenv().AutograbEnabled = state
    if state then
        task.spawn(function()
            while getgenv().AutograbEnabled do
                task.wait(0.1) -- Оптимальний делей для Android, щоб не було фризів
                pcall(function()
                    -- Варіант 1: Через ProximityPrompts (як у Xen_Hub)
                    for _, prompt in pairs(Workspace:GetDescendants()) do
                        if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                            local char = LocalPlayer.Character
                            local hrp = char and char:FindFirstChild("HumanoidRootPart")
                            if hrp and (hrp.Position - prompt.Parent:GetPivot().Position).Magnitude <= 25 then
                                fireproximityprompt(prompt, 1)
                            end
                        end
                    end
                    
                    -- Варіант 2: Збір падаючих або статичних об'єктів/монет на карті
                    local drops = Workspace:FindFirstChild("Drops") or Workspace:FindFirstChild("DroppedItems")
                    if drops then
                        for _, item in pairs(drops:GetChildren()) do
                            local char = LocalPlayer.Character
                            local hrp = char and char:FindFirstChild("HumanoidRootPart")
                            if hrp and item:IsA("BasePart") then
                                item.CFrame = hrp.CFrame
                            end
                        end
                    end
                end)
            end
        end)
    end
end

-- ========================================================================
-- ФУНКЦІЯ 3: INVISIBLE STEAL (ПОВНА НЕВИДИМІСТЬ ПРИ КРАДІЖЦІ)
-- ========================================================================
-- Базується на коді з 44s_Hub та BK_hub_fresh_version
local function ToggleInvisibleSteal(state)
    getgenv().InvisibleStealEnabled = state
    pcall(function()
        local char = LocalPlayer.Character
        local lowerTorso = char and char:FindFirstChild("LowerTorso")
        local rootPart = char and char:FindFirstChild("HumanoidRootPart")
        
        if state then
            if lowerTorso and rootPart then
                -- Ламаємо з'єднання RootJoint клієнтським методом для увімкнення невидимості
                local rootJoint = lowerTorso:FindFirstChild("RootJoint")
                if rootJoint then
                    rootJoint.Parent = nil
                    getgenv().SavedRootJoint = rootJoint
                end
                -- Спускаємося під карту для безпечного стілу
                rootPart.CFrame = rootPart.CFrame * CFrame.new(0, -25, 0)
            end
            Rayfield:Notify({Title = "Invisible Steal", Content = "Повна невидимість увімкнена. Ви під картою.", Duration = 4})
        else
            -- Повертаємо персонажа до нормального стану
            if getgenv().SavedRootJoint and lowerTorso then
                getgenv().SavedRootJoint.Parent = lowerTorso
            end
            LocalPlayer:ResetCharacter() -- Безпечний ресет для стабілізації Android клієнта
        end
     pcall(function()
        -- Автоматичний тригер івентів крадіжки з 44s_Hub, якщо вони існують у грі
        if state and ReplicatedStorage:FindFirstChild("Packages") then
            local net = ReplicatedStorage.Packages:FindFirstChild("Net")
            if net and net:FindFirstChild("RE/StealService/DeliverySteal") then
                net["RE/StealService/DeliverySteal"]:FireServer()
            end
        end
     end)
   end)
end

-- ========================================================================
-- ФУНКЦІЯ 4: SEMI INVISIBLE (НАПІВНЕВИДИМІСТЬ / ПРОЗОРИЙ ESP-БЕКАП)
-- ========================================================================
-- Модифікована логіка рендерингу частин тіла на базі чистки анімацій з Xen_Hub
local function ToggleSemiInvisible(state)
    getgenv().SemiInvisibleEnabled = state
    pcall(function()
        local char = LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") or part:IsA("Decal") then
                    if part.Name ~= "HumanoidRootPart" then
                        part.Transparency = state and 0.75 or 0 -- Робимо напівпрозорим на 75%
                    end
                end
            end
        end
    end)
end


