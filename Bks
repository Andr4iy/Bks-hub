-- Маскування та патч синхронізатора, щоб сервер не бачив чит-потоки
pcall(function()
    local Sync = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Synchronizer", 5)
    if Sync then
        local SyncModule = require(Sync)
        for name, fn in pairs(SyncModule) do
            if typeof(fn) == "function" and not isexecutorclosure(fn) then
                local ok, ups = pcall(debug.getupvalues, fn)
                if ok then
                    for idx, val in pairs(ups) do
                        if typeof(val) == "function" and not isexecutorclosure(val) then
                            debug.setupvalue(fn, idx, newcclosure(function() end))
                        end
                    end
                end
            end
        end
    end
end)

-- РЕМОУТ-СПООФЕР (Шифрування пакетів крадіжки з sources_hub_on_top)
local DecryptedRemotes = {}
local function GetSafeRemote(name)
    if DecryptedRemotes[name] then return DecryptedRemotes[name] end
    local NetFolder = ReplicatedStorage.Packages:FindFirstChild("Net")
    if NetFolder then
        for _, child in pairs(NetFolder:GetChildren()) do
            if child.Name == name then
                DecryptedRemotes[name] = child
                return child
            end
        end
    end
    return nil
end

