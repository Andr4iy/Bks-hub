-- 1. ЛЕГІТИМНИЙ АВТОЗБІР (Кожні 0.3 сек, невеликий радіус — античит не палить)
CreateToggle("Safe Autograb", 1, function(state)
    getgenv().GhostAutograb = state
    if state then
        task.spawn(function()
            while getgenv().GhostAutograb do
                task.wait(0.3)
                pcall(function()
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then return end

                    for _, prompt in pairs(Workspace:GetDescendants()) do
                        if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                            -- Перевіряємо дистанцію, щоб сервер не кікав за "клік здалеку"
                            if (hrp.Position - prompt.Parent:GetPivot().Position).Magnitude <= 15 then
                                fireproximityprompt(prompt, 0)
                            end
                        end
                    end
                end)
            end
        end)
    end
end)

-- 2. ВЕКТОРНИЙ ДЕСИНХРОН (Збиває приціл без ТП)
